{
  "name": "amc-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --cache \"**/*.{js,ts,svelte,json,md,css,html}\"",
    "lint": "prettier --check --cache \"**/*.{js,ts,svelte,json,md,css,html}\" && eslint \"**/*.{js,ts,svelte}\"",
    "lint:fix": "eslint --fix \"**/*.{js,ts,svelte}\"",
    "test:unit": "vitest",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "paraglide:compile": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "proto:generate": "buf generate",
    "checklist": "pnpm format && pnpm lint && pnpm paraglide:compile && pnpm check && pnpm test"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.68.2",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "10.0.1",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/sveltekit": "10.3.5",
    "@types/env-ci": "3.1.4",
    "@types/lodash-es": "4.17.12",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-webdriverio": "4.1.4",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.3.5",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.5.0",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react": "19.2.5",
    "storybook": "10.3.5",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4",
    "vitest-browser-svelte": "2.1.1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@fontsource-variable/noto-sans": "5.2.10",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "@fontsource-variable/noto-sans-kr": "5.2.10",
    "@fontsource-variable/noto-sans-mono": "5.2.10",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fontsource-variable/noto-sans-thai": "5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/kanit": "5.2.8",
    "@fontsource/koulen": "5.2.7",
    "@iconify-json/material-symbols": "1.2.67",
    "@inlang/paraglide-js": "2.16.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@unocss/extractor-svelte": "66.6.8",
    "amc-uno-css-config": "github:ASEAN-Motor-Club/uno-css-config#9ae00ce11190237610eb3f92b615773148090504",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "dompurify": "3.4.0",
    "env-ci": "11.2.0",
    "gsap": "3.15.0",
    "lodash-es": "4.18.1",
    "lottie-web": "5.13.0",
    "maplibre-gl": "5.23.0",
    "marked": "18.0.2",
    "ol": "10.9.0",
    "quaternion": "2.2.0",
    "svelte": "5.55.4",
    "svelte-portal": "2.2.1",
    "tailwind-merge": "3.5.0",
    "terser": "5.46.1",
    "unocss": "66.6.8",
    "vite": "8.0.8",
    "vite-bundle-analyzer": "1.3.7",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.16.0"
  },
