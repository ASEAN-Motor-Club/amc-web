{
  "name": "amc-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write --cache \"**/*.{js,ts,svelte,json,md,css,html}\"",
    "lint": "prettier --check --cache \"**/*.{js,ts,svelte,json,md,css,html}\" && eslint \"**/*.{js,ts,svelte}\"",
    "lint:fix": "eslint --fix \"**/*.{js,ts,svelte}\"",
    "test:unit": "vitest",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "paraglide:compile": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "proto:generate": "buf generate",
    "checklist": "pnpm format && pnpm lint && pnpm paraglide:compile && pnpm check && pnpm test"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.70.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-themes": "10.4.2",
    "@storybook/sveltekit": "10.4.2",
    "@types/env-ci": "3.1.4",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.9.3",
    "@vitest/browser": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-storybook": "10.4.2",
    "eslint-plugin-svelte": "3.19.0",
    "globals": "17.6.0",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.1.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.7",
    "storybook": "10.4.2",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8",
    "vitest-browser-svelte": "2.1.1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@fontsource-variable/noto-sans": "5.2.10",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "@fontsource-variable/noto-sans-kr": "5.2.10",
    "@fontsource-variable/noto-sans-mono": "5.2.10",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fontsource-variable/noto-sans-thai": "5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/kanit": "5.2.8",
    "@fontsource/koulen": "5.2.7",
    "@iconify-json/material-symbols": "1.2.76",
    "@inlang/paraglide-js": "2.18.2",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.63.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@unocss/extractor-svelte": "66.7.0",
    "@vitest/browser-playwright": "4.1.8",
    "amc-uno-css-config": "github:ASEAN-Motor-Club/uno-css-config#9ae00ce11190237610eb3f92b615773148090504",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "dompurify": "3.4.8",
    "env-ci": "11.2.0",
    "gsap": "3.15.0",
    "lodash-es": "4.18.1",
    "lottie-web": "5.13.0",
    "marked": "18.0.5",
    "ol": "10.9.0",
    "pakop": "workspace:*",
    "quaternion": "2.2.0",
    "svelte": "5.56.2",
    "svelte-portal": "2.2.1",
    "tailwind-merge": "3.6.0",
    "terser": "5.48.0",
    "unocss": "66.7.0",
    "vite": "8.0.16",
    "vite-bundle-analyzer": "1.3.8",
    "vite-plugin-wasm": "3.6.0",
    "wasm-map": "workspace:*",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
